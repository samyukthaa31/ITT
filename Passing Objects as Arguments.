#include <iostream>
using namespace std;
class Distance {
private:
    int km;
    int meter;
public:
    Distance(int k = 0, int m = 0) {
        km = k;
        meter = m;

        convert();
    }
    void convert() {
        if (meter >= 1000) {
            km += meter / 1000;
            meter = meter % 1000;
        }
    }
    Distance add(Distance d) {
        Distance temp;
        temp.km = km + d.km;
        temp.meter = meter + d.meter;
        temp.convert();
        return temp;
    }
    void display() {
        cout << km << " km and " << meter << " meters" << endl;
    }
};

int main() {
    Distance d1(5, 1200);
    Distance d2(3, 900);

    Distance d3 = d1.add(d2);
    cout << "Distance 1: "; d1.display();
    cout << "Distance 2: "; d2.display();
    cout << "Total Distance: "; d3.display();
    return 0;
}
